# auto-optim-agent environment template
#
# Copy to .env and fill in only what you need. .env is gitignored.
#
# The PRIMARY execution path for the memory-ingest skill is the PI harness,
# authenticated via Codex subscription. PI manages its own credentials at
# ~/.pi/agent/auth.json — repo scripts never read that file.
#
# OPENAI_API_KEY below is a FALLBACK for tools that sit outside the harness
# (e.g. a future direct sanity check). The ingest pipeline does NOT use it.
OPENAI_API_KEY=
